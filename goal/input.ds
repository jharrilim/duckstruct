struct Printer {
  text = "";

  write(s = this.text) {
    console.log(s)
  }
}

struct Story {
  private static story = "a story";
  header = "This is {.story} all about how,";
  body() => "my life got flipped, turned upside down";

  read() {
    let p = new Printer {
      text: header + " " + body(),
    };
    p.write()
  }
}

f main() {
  let p = new Printer { };
  p.write("Hello world");
  new Story { }.read();
}
