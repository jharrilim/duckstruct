{
	"name": "duckstruct-vscode",
	"description": "VS Code extension for Duckstruct",
	"author": "jharrilim",
	"license": "MIT",
	"version": "0.1.0",
	"publisher": "jharrilim",
	"repository": {
		"type": "git",
		"url": "https://github.com/jharrilim/duckstruct"
	},
	"categories": [
		"Programming Languages",
		"Other"
	],
	"keywords": [
		"duckstruct",
		"language",
		"server"
	],
	"engines": {
		"vscode": "^1.75.0"
	},
	"main": "./client/out/extension",
	"contributes": {
		"languages": [
			{
				"id": "duckstruct",
				"extensions": [
					".ds"
				],
				"configuration": "./language-configuration.json"
			}
		],
		"grammars": [
			{
				"language": "duckstruct",
				"scopeName": "source.duckstruct",
				"path": "./syntaxes/duckstruct.tmLanguage.json"
			}
		],
		"configuration": {
			"type": "object",
			"title": "Duckstruct language server",
			"properties": {
				"languageServerExample.maxNumberOfProblems": {
					"scope": "resource",
					"type": "number",
					"default": 100,
					"description": "Controls the maximum number of problems produced by the server."
				},
				"languageServerExample.trace.server": {
					"scope": "window",
					"type": "string",
					"enum": [
						"off",
						"messages",
						"verbose"
					],
					"default": "off",
					"description": "Traces the communication between VS Code and the language server."
				},
				"languageServerExample.duckstructPath": {
					"scope": "resource",
					"type": "string",
					"default": "ds",
					"description": "Path to the Duckstruct CLI binary used for diagnostics (`check --json`). Default `ds` uses PATH; use an absolute path to the `ds` you build (e.g. from `cargo metadata` target_directory/debug/ds when CARGO_TARGET_DIR redirects workspace target/debug)."
				}
			}
		}
	},
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"compile": "tsc -b",
		"watch": "tsc -b -w",
		"lint": "eslint ./client/src ./server/src --ext .ts,.tsx",
		"package": "vsce package",
		"publish": "vsce publish",
		"postinstall": "cd client && npm install && cd ../server && npm install && cd ..",
		"test": "sh ./scripts/e2e.sh"
	},
	"devDependencies": {
		"@types/mocha": "^9.1.0",
		"@types/node": "^16.11.7",
		"@typescript-eslint/eslint-plugin": "^5.54.0",
		"@typescript-eslint/parser": "^5.54.0",
		"@vscode/vsce": "^3.9.1",
		"eslint": "^8.35.0",
		"mocha": "^9.2.1",
		"typescript": "^4.9.5"
	}
}
